import java.util.Scanner;
class BankAccount {
    private double balance;

    public BankAccount(double initialBalance) {
        //  to prevent negative balance
        if (initialBalance >= 0) {
            this.balance = initialBalance;
        } else {
            this.balance = 0.0;
        }
    }
    public double getBalance() {
        return this.balance;
    }
    public boolean deposit(double amount) {
        if (amount > 0) {
            this.balance += amount;
            return true;
        }
        return false;
    }

    // --- Step 3 & 6: Withdraw method with validation ---
    public boolean withdraw(double amount) {
        if (amount > 0 && amount <= this.balance) {
            this.balance -= amount;
            return true;
        }
        return false;
    }
}

class ATM {
    // Step 5: Connect ATM class with the BankAccount class
    private BankAccount userAccount;
    private Scanner scanner;

    public ATM(BankAccount account) {
        this.userAccount = account;
        this.scanner = new Scanner(System.in);
    }

    // --- Step 2: User Interface Design ---
    public void start() {
        int choice;
        do {
            System.out.println("\n==============================");
            System.out.println("         ATM INTERFACE        ");
            System.out.println("==============================");
            System.out.println("1. Check Balance");
            System.out.println("2. Deposit Money");
            System.out.println("3. Withdraw Money");
            System.out.println("4. Exit");
            System.out.print("Select an option (1-4): ");
            while (!scanner.hasNextInt()) {
                System.out.print("Please enter a number (1-4): ");
                scanner.next();
            }
            choice = scanner.nextInt();

            switch (choice) {
                case 1:
                    checkBalance();
                    break;
                case 2:
                    handleDeposit();
                    break;
                case 3:
                    handleWithdraw();
                    break;
                case 4:
                    System.out.println("\nThank you!");
                    break;
                default:
                    System.out.println("Invalid option.");
            }
        } while (choice != 4);
    }

    // --- Step 3 & 7: Implementation and Message Display ---
    private void checkBalance() {
        System.out.printf("\n[BALANCE] Your current balance is: $%.2f\n", userAccount.getBalance());
    }

    private void handleDeposit() {
        System.out.print("\nEnter amount to deposit: $");
        if (scanner.hasNextDouble()) {
            double amount = scanner.nextDouble();
            // Step 6 & 7: Validate and display result
            if (userAccount.deposit(amount)) {
                System.out.printf(" Success: $%.2f deposited successfully.\n", amount);
                checkBalance();
            } else {
                System.out.println(" Error: Deposit amount must be greater than $0.");
            }
        } else {
            System.out.println("Error: Invalid input formatting.");
            scanner.next();
        }
    }

    private void handleWithdraw() {
        System.out.print("\nEnter amount to withdraw: $");
        if (scanner.hasNextDouble()) {
            double amount = scanner.nextDouble();

            // Step 6 & 7: Validate bounds, funds, and display result
            if (amount <= 0) {
                System.out.println("Error: Withdrawal amount must be greater than $0.");
            } else if (userAccount.withdraw(amount)) {
                System.out.printf("Success: $%.2f withdrawn successfully.\n", amount);
                checkBalance();
            } else {
                System.out.println("Error: Insufficient funds or processing limits breached.");
            }
        } else {
            System.out.println("Error: Invalid input formatting.");
            scanner.next();
        }
    }
}
public class Main {
    public static void main(String[] args) {
        BankAccount account = new BankAccount(1000.00);
        ATM atmMachine = new ATM(account);
        atmMachine.start();
    }
}
